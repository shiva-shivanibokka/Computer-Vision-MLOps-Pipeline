# Copy to .env and fill in to connect the free managed backends.
# Everything runs locally with these UNSET (SQLite MLflow + local weights).

# --- DagsHub (free hosted MLflow tracking server + model registry) ---
# From your DagsHub repo:  Remote -> Experiments -> MLflow.
# MLFLOW_TRACKING_URI=https://dagshub.com/<user>/<repo>.mlflow
# MLFLOW_TRACKING_USERNAME=<dagshub-user>
# MLFLOW_TRACKING_PASSWORD=<dagshub-token>

# --- Serving overrides (optional) ---
# LOCAL_WEIGHTS=artifacts/best.pt
# PREDICTION_DB=artifacts/predictions.db
